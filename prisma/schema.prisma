generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ────────────────────────────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  password          String
  name              String
  role              UserRole  @default(WOMAN)
  language          String    @default("pt") // idioma da conta: UI + Rafa (pt|en|es)
  resetToken        String?   @unique
  resetTokenExpiry  DateTime?

  // Assinatura (camada recorrente — Rafa ilimitada + comunidade)
  stripeCustomerId             String?            @unique
  subscriptionId               String?            @unique
  subscriptionStatus           SubscriptionStatus @default(NONE)
  subscriptionCurrentPeriodEnd DateTime?

  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  profile        Profile?
  coupleProfile  CoupleProfile?  @relation("PrimaryUser")
  spouseProfile  CoupleProfile?  @relation("SpouseUser")
  purchases      ModulePurchase[]
  sessions       TherapySession[]
  journalEntries JournalEntry[]
  assessments    Assessment[]
  progress       UserProgress[]
  milestones     Milestone[]
  devotionalLogs DevotionalLog[]
  streakState    StreakState?
  gardenBeds     GardenBed[]

  @@map("users")
}

enum UserRole {
  WOMAN
  COUPLE
  FAMILY
  LEADER
  ADMIN
}

enum SubscriptionStatus {
  NONE
  ACTIVE
  PAST_DUE
  CANCELED
}

// ─── Profile ─────────────────────────────────────────────────────────────────

model Profile {
  id               String    @id @default(cuid())
  userId           String    @unique
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio              String?
  birthDate        DateTime?
  cycleStartDate   DateTime?
  cycleLengthDays  Int?      @default(28)
  churchBackground String?
  hebrewRoots      Boolean   @default(false)
  primaryGoal      String?
  currentSeason    String?
  avatarUrl        String?
  timezone         String    @default("America/Sao_Paulo")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@map("profiles")
}

model CoupleProfile {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation("PrimaryUser", fields: [userId], references: [id], onDelete: Cascade)
  spouseId     String?   @unique
  spouse       User?     @relation("SpouseUser", fields: [spouseId], references: [id])
  marriageDate DateTime?
  createdAt    DateTime  @default(now())

  @@map("couple_profiles")
}

// ─── Assessment ──────────────────────────────────────────────────────────────

model Assessment {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type        AssessmentType
  completedAt DateTime?
  score       Json?
  report      String?          @db.Text
  answers     AssessmentAnswer[]
  recommendations AssessmentRecommendation[]
  createdAt   DateTime         @default(now())

  @@map("assessments")
}

enum AssessmentType {
  INITIAL
  EMOTIONAL_HEALTH
  IDENTITY
  MARRIAGE
  FAMILY
  LEADERSHIP
  HORMONAL
  PERIODIC
}

model AssessmentQuestion {
  id           String            @id @default(cuid())
  type         AssessmentType
  order        Int
  text         String
  subtext      String?
  category     String
  inputType    QuestionInputType
  options      Json?
  scriptureRef String?
  answers      AssessmentAnswer[]

  @@map("assessment_questions")
}

enum QuestionInputType {
  SCALE
  MULTIPLE_CHOICE
  TEXT
  YES_NO
}

model AssessmentAnswer {
  id           String             @id @default(cuid())
  assessmentId String
  assessment   Assessment         @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  questionId   String
  question     AssessmentQuestion @relation(fields: [questionId], references: [id])
  value        String
  createdAt    DateTime           @default(now())

  @@unique([assessmentId, questionId])
  @@map("assessment_answers")
}

model AssessmentRecommendation {
  id           String     @id @default(cuid())
  assessmentId String
  assessment   Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  moduleId     String
  module       Module     @relation(fields: [moduleId], references: [id])
  priority     Int
  reason       String
  createdAt    DateTime   @default(now())

  @@map("assessment_recommendations")
}

// ─── Modules ─────────────────────────────────────────────────────────────────

model Module {
  id                   String     @id @default(cuid())
  slug                 String     @unique
  title                String
  subtitle             String?
  description          String     @db.Text
  audience             UserRole[]
  iconEmoji            String
  colorClass           String
  priceInCents         Int
  order                Int
  isActive             Boolean    @default(true)
  systemPromptAddition String?    @db.Text
  hebrewWord           String?
  keyScriptures        Json?
  createdAt            DateTime   @default(now())
  updatedAt            DateTime   @updatedAt

  lessons         Lesson[]
  purchases       ModulePurchase[]
  journalPrompts  JournalPromptTemplate[]
  progress        UserProgress[]
  recommendations AssessmentRecommendation[]
  translations    ModuleTranslation[]

  @@map("modules")
}

// Conteúdo traduzível de um módulo, uma linha por locale (en, es).
// PT é a língua-base (campos do próprio Module) e nunca tem linha aqui.
model ModuleTranslation {
  id            String   @id @default(cuid())
  moduleId      String
  module        Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  locale        String
  title         String?
  subtitle      String?
  description    String?  @db.Text
  hebrewWord    String?
  keyScriptures Json?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([moduleId, locale])
  @@map("module_translations")
}

model Lesson {
  id          String      @id @default(cuid())
  moduleId    String
  module      Module      @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  title       String
  slug        String
  order       Int
  type        LessonType
  content     String      @db.Text
  audioUrl    String?
  videoUrl    String?
  durationMin Int?
  scripture   String?
  prayer      String?     @db.Text
  exercise    String?     @db.Text
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  progress    LessonProgress[]
  translations LessonTranslation[]

  @@unique([moduleId, slug])
  @@map("lessons")
}

// Conteúdo traduzível de uma lição, uma linha por locale (en, es).
// PT é a língua-base (campos da própria Lesson) e nunca tem linha aqui.
model LessonTranslation {
  id        String   @id @default(cuid())
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  locale    String
  title     String?
  content   String?  @db.Text
  scripture String?
  prayer    String?  @db.Text
  exercise  String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([lessonId, locale])
  @@map("lesson_translations")
}

enum LessonType {
  TEACHING
  PRACTICE
  SCRIPTURE
  ENDOCRINOLOGY
  COUNSELING
}

// ─── Purchases ───────────────────────────────────────────────────────────────

model ModulePurchase {
  id              String         @id @default(cuid())
  userId          String
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId        String
  module          Module         @relation(fields: [moduleId], references: [id])
  stripeSessionId String?        @unique
  stripePaymentId String?
  amountPaid      Int
  currency        String         @default("BRL")
  status          PurchaseStatus @default(PENDING)
  purchasedAt     DateTime?
  createdAt       DateTime       @default(now())

  @@unique([userId, moduleId])
  @@map("module_purchases")
}

enum PurchaseStatus {
  PENDING
  COMPLETED
  REFUNDED
  FAILED
}

// ─── Therapy Sessions ────────────────────────────────────────────────────────

model TherapySession {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId  String?
  title     String?
  summary   String?          @db.Text
  mood      Int?
  moodEnd   Int?
  messages  SessionMessage[]
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  @@map("therapy_sessions")
}

model SessionMessage {
  id        String         @id @default(cuid())
  sessionId String
  session   TherapySession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role      MessageRole
  content   String         @db.Text
  tokens    Int?
  createdAt DateTime       @default(now())

  @@map("session_messages")
}

enum MessageRole {
  USER
  ASSISTANT
}

// ─── Journaling ──────────────────────────────────────────────────────────────

model JournalEntry {
  id           String                 @id @default(cuid())
  userId       String
  user         User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId     String?
  promptId     String?
  prompt       JournalPromptTemplate? @relation(fields: [promptId], references: [id])
  title        String?
  content      String                 @db.Text
  mood         Int?
  gratitude    String?
  scripture    String?
  insight      String?
  cyclePhase   CyclePhase?
  aiReflection String?                @db.Text

  // Journaling de 4 perspectivas (método Blooming): evento → emoção → empatia →
  // dinâmica. A 4ª (o que aconteceu com o RELACIONAMENTO) é a inovação. Opcionais
  // e estruturadas p/ a IA ler padrões por área. gardenKey liga a entrada a um
  // canteiro do Jardim (a ponte journaling → cultivo).
  pEvent       String?                @db.Text // O que aconteceu
  pEmotion     String?                @db.Text // O que aconteceu dentro de mim
  pEmpathy     String?                @db.Text // O que talvez acontecia no outro
  pDynamic     String?                @db.Text // O que aconteceu com o relacionamento
  gardenKey    String?                // voce|casamento|familia|amizades|casa|trabalho|deus|legado

  createdAt    DateTime               @default(now())
  updatedAt    DateTime               @updatedAt

  @@map("journal_entries")
}

enum CyclePhase {
  MENSTRUAL
  FOLLICULAR
  OVULATORY
  LUTEAL
}

model JournalPromptTemplate {
  id         String      @id @default(cuid())
  moduleId   String?
  module     Module?     @relation(fields: [moduleId], references: [id])
  category   String
  cyclePhase CyclePhase?
  title      String
  prompt     String      @db.Text
  scripture  String?
  isActive   Boolean     @default(true)
  entries    JournalEntry[]
  createdAt  DateTime    @default(now())

  @@map("journal_prompt_templates")
}

// ─── Progress ────────────────────────────────────────────────────────────────

model UserProgress {
  id              String          @id @default(cuid())
  userId          String
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  moduleId        String
  module          Module          @relation(fields: [moduleId], references: [id])
  startedAt       DateTime        @default(now())
  completedAt     DateTime?
  percentComplete Int             @default(0)
  lessonProgress  LessonProgress[]

  @@unique([userId, moduleId])
  @@map("user_progress")
}

model LessonProgress {
  id          String       @id @default(cuid())
  progressId  String
  progress    UserProgress @relation(fields: [progressId], references: [id], onDelete: Cascade)
  lessonId    String
  lesson      Lesson       @relation(fields: [lessonId], references: [id])
  completedAt DateTime?
  notes       String?

  @@unique([progressId, lessonId])
  @@map("lesson_progress")
}

model Milestone {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  title       String
  description String?
  type        MilestoneType
  moduleId    String?
  metadata    Json?
  achievedAt  DateTime      @default(now())

  @@map("milestones")
}

enum MilestoneType {
  MODULE_STARTED
  MODULE_COMPLETED
  JOURNAL_STREAK
  SESSION_COUNT
  ASSESSMENT_DONE
  BREAKTHROUGH
}

// ─── Devocional (hábito diário + streak) ─────────────────────────────────────

model DevotionalLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime @db.Date
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@map("devotional_logs")
}

// Um canteiro do Jardim — uma área da vida que a Jardineira cultiva (Você,
// Casamento, Família, Amizades, Casa, Trabalho, Deus, Legado). O Jardim mede
// CULTIVO, não humor: florescimento 1-5 + quão recente foi regado. Sem linha =
// área ainda não cultivada (neutra, nunca "falha"). key = chave estável do eixo.
model GardenBed {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  key          String    // voce | casamento | familia | amizades | casa | trabalho | deus | legado
  flourishing  Int?      // 1..5 (autoavaliação de quanto floresce); null = ainda não cultivado
  note         String?   // uma linha do que está cultivando aqui
  lastTendedAt DateTime?

  // Motor de Evolução: a Rafa lê os registros do diário marcados a este canteiro
  // (gardenKey) + o estado, e devolve uma observação de cultivo (padrão, não rótulo;
  // pergunta, não diagnóstico — Constituição). Gerada sob demanda, guardada aqui.
  reflection   String?   @db.Text
  reflectedAt  DateTime?

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@unique([userId, key])
  @@map("garden_beds")
}

// Estado durável do streak de "Presença" — devocional OU Rafa OU diário alimentam
// o mesmo streak. graceDays cobrem uma falha sem zerar ("as misericórdias se
// renovam a cada manhã" — Lm 3:23). É o anti-Duolingo: restaura, não pune.
model StreakState {
  id           String    @id @default(cuid())
  userId       String    @unique
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  current      Int       @default(0)
  best         Int       @default(0)
  graceDays    Int       @default(0)
  lastActiveOn DateTime? @db.Date
  updatedAt    DateTime  @updatedAt

  @@map("streak_states")
}
